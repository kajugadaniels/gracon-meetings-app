# app/meetings environment template.
# Copy to .env.local for local development. Do not commit real values.

NEXT_PUBLIC_MEETINGS_URL=http://localhost:4003
NEXT_PUBLIC_APP_URL=http://localhost:4000
NEXT_PUBLIC_MAIN_APP_URL=http://localhost:4000
NEXT_PUBLIC_MEETINGS_API_URL=http://localhost:3007/api/v1
NEXT_PUBLIC_AUTH_API_URL=http://localhost:3000/api/v1

# Stream public key only. The Stream secret belongs in api/meetings.
NEXT_PUBLIC_STREAM_API_KEY=

# Shared Gracon session cookie policy. Do not set AUTH_COOKIE_DOMAIN for
# localhost development. Production should use a parent domain such as
# .gracon360.com and HttpOnly server-owned cookies.
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_ACCESS_TOKEN_TTL=15m
AUTH_REFRESH_TOKEN_TTL=1d
AUTH_REFRESH_ROTATION=true
AUTH_REUSE_DETECTION=true

# Keep this false for local development so app/meetings can use its own login.
# Production should set true and hand login to app/app.
MEETINGS_USE_MAIN_APP_LOGIN=false
NEXT_PUBLIC_MEETINGS_USE_MAIN_APP_LOGIN=false
ALLOW_DEV_READABLE_AUTH_COOKIES=true
NEXT_PUBLIC_ALLOW_DEV_READABLE_AUTH_COOKIES=true
